{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "react", "react-dom"]
  },
  "include": [".storybook/**/*.ts", ".storybook/**/*.tsx"]
}
